# -------- Build Stage --------
FROM maven:3.9.5-eclipse-temurin-17 AS build
WORKDIR /app
COPY . .
RUN mvn clean package -DskipTests

# -------- Runtime Stage --------
FROM eclipse-temurin:17-jre-alpine

# Create non-root user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

# Copy jar from build stage
COPY --from=build /app/target/demoapp-1.0.0.jar demoapp.jar

# Change ownership to non-root user
RUN chown -R appuser:appgroup /app

# Switch to non-root user
USER appuser

# Expose application port
EXPOSE 8080

# Health check (Spring Boot Actuator or root URL)
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:8080/ || exit 1

# Run application
CMD ["java", "-jar", "demoapp.jar"]


//“This is a Spring Boot application built using Maven in a multi-stage Docker build. 
In the first stage, we use a Maven image with JDK 17 to compile and package the application into a JAR. 
In the second stage, we use a lightweight JRE image to run the application as a non-root user, with health checks and proper security hardening.”//
